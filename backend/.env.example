CONVEX_DEPLOYMENT="dev:formal-gerbil-679"
CONVEX_URL="https://formal-gerbil-679.convex.cloud"
# Clerk (legacy — kept only during the dual-accept window, remove at cutover/Phase 5)
CLERK_WEBHOOK_SECRET=""
# AI Agents auth service (RS256 JWT verification via JWKS)
AUTH_SERVICE_URL="https://auth.ai-agents.com"
AUTH_JWKS_URL="https://auth.ai-agents.com/.well-known/jwks.json"
# Must match auth service JWT_ISSUER / JWT_AUDIENCE (jwt.service.ts) exactly,
# or every authenticated request 401s on issuer mismatch.
AUTH_ISSUER="https://auth.ai-agents.com"
AUTH_AUDIENCE="ai-agents"
E2B_API_KEY=""
E2B_SANDBOX_DOMAIN=""
OPENAI_API_KEY=""
TAVILY_API_KEY=""
GROQ_API_KEY=""
GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""
KEY_ENCRYPTION_SECRET="replace-with-strong-secret"
OPENAI_BASE_URL="https://api.openai.com/v1"
DASHSCOPE_BASE_URL="https://dashscope-intl.aliyuncs.com/compatible-mode/v1"
GROQ_BASE_URL="https://api.groq.com/openai/v1"
ANTHROPIC_BASE_URL="https://api.anthropic.com/v1"
DEFAULT_LLM_PROVIDER="QWEN_DASHSCOPE"

# ── Azure OpenAI (core agent) ────────────────────────────────────────────────
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_DEPLOYMENT="gpt-5.5"

# ── Azure OpenAI (CLI-only deployment, Responses API / codex model) ─────────
# Separate from AZURE_OPENAI_DEPLOYMENT above — agentRunner/modelSelector use
# Chat Completions and can't call codex/reasoning models, so the CLI provider
# handout (routes/cli.ts) needs its own deployment name.
AZURE_OPENAI_CLI_DEPLOYMENT="gpt-5.3-codex"

# ── Azure Claude passthrough (CLI) ───────────────────────────────────────────
AZURE_CLAUDE_API_KEY=""
AZURE_CLAUDE_ENDPOINT=""
AZURE_CLAUDE_DEPLOYMENT=""
DATABASE_URL="postgresql://username:password@localhost:5432/ai-agents"
NEON_API_KEY=""
NEON_ORG_ID=""
NEON_PROJECT_ID=""
NEON_BRANCH_ID=""
NEON_ROLE_NAME="neondb_owner"

# App URLs
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:8000"

# ai-agents-infra API (POST /deploy). Must match PORT in ai-agents-infra/.env and
# NEXT_PUBLIC_DEPLOY_URL in frontend/.env (same host:port for deploy + live log SSE).
DEPLOY_SERVICE_URL="http://localhost:8083"

# GitHub OAuth App (https://github.com/settings/developers)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ── Queue (BullMQ + Upstash Redis) ──────────────────────────────────────────
# Use rediss:// for TLS (Upstash always requires TLS)
REDIS_URL="rediss://default:<token>@<host>.upstash.io:6379"

# ── Edge Router (Upstash Redis for Cloudflare Worker routing) ───────────────
# Separate Upstash instance (or same URL) used by deploy-callback to save
# frontend/backend routing metadata that Cloudflare Workers read at the edge.
UPSTASH_REDIS_URL="rediss://default:<token>@<host>.upstash.io:6379"

# Deploy callback auth
DEPLOY_CALLBACK_SECRET=""

# Deploy rate limit (per workspace, rolling window). Uses REDIS_URL. On Redis errors, requests are allowed (fail-open).
# Set DEPLOY_RATE_LIMIT_ENABLED=false to disable.
DEPLOY_RATE_LIMIT_ENABLED="true"
DEPLOY_RATE_LIMIT_PER_WORKSPACE="5"
DEPLOY_RATE_LIMIT_WINDOW_SECONDS="3600"

# Concurrency per worker process (tune per EC2 instance size)
WORKER_CONCURRENCY=5
SETUP_WORKER_CONCURRENCY=3
IMPORT_WORKER_CONCURRENCY=2

# ── Blob storage (chat image bucket) ────────────────────────────────────────
# Driver: "supabase" (default). Add "s3" later by implementing createS3Store()
# in src/services/storageService.ts and adding a case to selectDriver().
STORAGE_DRIVER="supabase"
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="chat-images"
SUPABASE_SCREENSHOTS_BUCKET="deployment-screenshots"

# ── Demo Access (invite-only feature) ───────────────────────────────────────
DEMO_ADMIN_EMAIL="admin@ai-agents.com"
DEMO_ADMIN_PASSWORD="DemoAdmin123!"
DEMO_CLAIM_RATE_LIMIT_PER_USER=10
DEMO_CLAIM_RATE_LIMIT_WINDOW_SECONDS=3600

# ── Router (OpenAI-compatible LLM gateway at /v1) ───────────────────────────
# Feature flag + kill switch. Unset/empty => /v1/chat and /v1/models return 503.
ROUTING_ENABLED=true
ROUTER_RPM_LIMIT=1000
